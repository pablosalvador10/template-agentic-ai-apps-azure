# ─── App ───────────────────────────────────────────────────────────
APP_NAME=agentic-template                        # Application name (used in logs and resource naming)
API_PORT=8001                                     # Backend API port
CORS_ORIGINS=http://localhost:5173                # Comma-separated allowed origins for CORS

# ─── Azure AI Foundry ──────────────────────────────────────────────
# Leave AZURE_FOUNDRY_PROJECT_ENDPOINT empty for local simulation mode.
# When set, the app uses foundrykit AgentManager to run real AI agents.
AZURE_FOUNDRY_PROJECT_ENDPOINT=                   # e.g. https://your-foundry.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_CHAT_MODEL=gpt-4.1-mini             # Azure OpenAI deployment name
FOUNDRY_CREDENTIAL_MODE=dev                       # "dev" = DefaultAzureCredential (az login), "managed_identity" = production
AZURE_CLIENT_ID=                                  # Required only when FOUNDRY_CREDENTIAL_MODE=managed_identity

# ─── Storage ───────────────────────────────────────────────────────
STORAGE_MODE=inmemory                             # "inmemory" (local dev) or "cosmos" (production)
COSMOS_ENDPOINT=                                  # e.g. https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE_NAME=agentic-template             # Cosmos DB database name
COSMOS_CONTAINER_MESSAGES=messages                # Container for chat messages (partition key: /session_id)
COSMOS_CONTAINER_SESSIONS=sessions                # Container for session metadata

# ─── Observability ─────────────────────────────────────────────────
OTEL_EXPORTER=console                             # "console" (local), "otlp" (collector), "azure" (App Insights)
OTEL_SERVICE_NAME=app-template-backend            # OpenTelemetry service name
OTEL_COLLECTOR_ENDPOINT=http://localhost:4318/v1/traces  # OTLP collector endpoint (when OTEL_EXPORTER=otlp)
APPLICATIONINSIGHTS_CONNECTION_STRING=            # Required when OTEL_EXPORTER=azure

# ─── MCP Server ────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8080/mcp           # MCP server endpoint for tool dispatch
