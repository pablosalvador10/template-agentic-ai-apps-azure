# ─── Azure Production Configuration ───────────────────────────────
# Copy to .env.azure and fill in real values before deploying.

# ─── App ───────────────────────────────────────────────────────────
APP_NAME=agentic-template
API_PORT=8001
CORS_ORIGINS=https://your-frontend-url             # Set to deployed frontend Container App URL

# ─── Azure AI Foundry (required for production) ───────────────────
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_CHAT_MODEL=gpt-4.1-mini
FOUNDRY_CREDENTIAL_MODE=managed_identity           # Use managed identity in Container Apps
AZURE_CLIENT_ID=                                   # User-assigned managed identity client ID

# ─── Storage (Cosmos DB in production) ─────────────────────────────
STORAGE_MODE=cosmos
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE_NAME=agentic-template
COSMOS_CONTAINER_MESSAGES=messages
COSMOS_CONTAINER_SESSIONS=sessions

# ─── Observability (Azure Monitor) ─────────────────────────────────
OTEL_EXPORTER=azure                                # Export traces/metrics to Application Insights
OTEL_SERVICE_NAME=app-template-backend
APPLICATIONINSIGHTS_CONNECTION_STRING=             # From Terraform output or Azure portal

# ─── MCP Server ────────────────────────────────────────────────────
MCP_SERVER_URL=https://your-mcp-server.example/mcp
